{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-consolidation-report.schema.json",
  "title": "Intelligence Consolidation Report",
  "description": "Generated review queue derived from the primitive inventory.",
  "type": "object",
  "required": [
    "schemaVersion",
    "inventoryGeneratedAt",
    "inventory",
    "counts",
    "promotionCandidates",
    "nameReviewQueue",
    "digestReviewQueue",
    "firstPartyNameCollisions",
    "firstPartyDigestMatches",
    "brokenSymlinks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "inventoryGeneratedAt": {
      "type": "string",
      "format": "date-time"
    },
    "inventory": {
      "type": "string",
      "enum": [
        "manifests/discovered-primitives.json"
      ]
    },
    "counts": {
      "type": "object",
      "required": [
        "byType",
        "byBucket",
        "byBucketAndType",
        "totalEntries",
        "nameReviewGroups",
        "digestReviewGroups",
        "firstPartyNameCollisions",
        "firstPartyDigestMatches",
        "brokenSymlinks"
      ],
      "properties": {
        "byType": {
          "$ref": "#/$defs/countMap"
        },
        "byBucket": {
          "$ref": "#/$defs/countMap"
        },
        "byBucketAndType": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/countMap"
          }
        },
        "totalEntries": {
          "type": "integer",
          "minimum": 0
        },
        "nameReviewGroups": {
          "type": "integer",
          "minimum": 0
        },
        "digestReviewGroups": {
          "type": "integer",
          "minimum": 0
        },
        "firstPartyNameCollisions": {
          "type": "integer",
          "minimum": 0
        },
        "firstPartyDigestMatches": {
          "type": "integer",
          "minimum": 0
        },
        "brokenSymlinks": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "promotionCandidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotionCandidate"
      }
    },
    "nameReviewQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nameReviewItem"
      }
    },
    "digestReviewQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/digestReviewItem"
      }
    },
    "firstPartyNameCollisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/firstPartyNameCollision"
      }
    },
    "firstPartyDigestMatches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/firstPartyDigestMatch"
      }
    },
    "brokenSymlinks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/brokenSymlink"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "candidateReference": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourceRoot",
        "path",
        "resolvedPath",
        "sha256",
        "bucket"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "promotionCandidate": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourceRoot",
        "path",
        "resolvedPath",
        "sha256",
        "bucket",
        "action"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "KEEP_CANONICAL",
            "REVIEW_PROMOTE"
          ]
        }
      },
      "additionalProperties": false
    },
    "nameReviewItem": {
      "type": "object",
      "required": [
        "type",
        "name",
        "priority",
        "action",
        "digests",
        "buckets",
        "entries"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "digests": {
          "type": "integer",
          "minimum": 1
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          },
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "digestReviewItem": {
      "type": "object",
      "required": [
        "sha256",
        "priority",
        "action",
        "buckets",
        "entries"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          },
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "firstPartyNameCollision": {
      "type": "object",
      "required": [
        "type",
        "name",
        "action",
        "entries"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "RENAME_OR_RECORD_INTENTIONAL_REPLACEMENT"
          ]
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          }
        }
      },
      "additionalProperties": false
    },
    "firstPartyDigestMatch": {
      "type": "object",
      "required": [
        "sha256",
        "action",
        "entries"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "action": {
          "type": "string",
          "enum": [
            "REWRITE_CANONICAL_DERIVATIVE"
          ]
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          }
        }
      },
      "additionalProperties": false
    },
    "brokenSymlink": {
      "type": "object",
      "required": [
        "sourceRoot",
        "sourceRootPath",
        "path",
        "observedPath",
        "target"
      ],
      "properties": {
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourceRootPath": {
          "$ref": "#/$defs/path"
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "observedPath": {
          "$ref": "#/$defs/path"
        },
        "target": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    }
  }
}
