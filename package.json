{
  "name": "intelligence",
  "private": true,
  "scripts": {
    "cli:run": "./gradlew -q :cli:run",
    "cli:install-dev": "./gradlew installDevelopmentCli",
    "package:cli": "./gradlew :cli:distTar :cli:distZip",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "marketplace:materialize": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace materialize --provider codex --out /tmp/intelligence-codex-marketplace",
    "marketplace:materialize:github": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace materialize --provider github --out /tmp/intelligence-github-marketplace",
    "marketplace:materialize:all": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace materialize --provider all --out /tmp/intelligence-marketplace",
    "marketplace:publish:preview": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace publish-branch --provider codex --branch codex --no-push",
    "marketplace:publish:github:preview": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace publish-branch --provider github --branch github --no-push",
    "marketplace:publish:all:preview": "./gradlew -q installDevelopmentCli && .local/intelligence/bin/intelligence marketplace publish-branch --provider all --branch marketplace --no-push",
    "schema:policy": "node source/skills/manage-json-schemas/scripts/schema-contracts.js policy-tree --root source/skills/manage-json-schemas/references/schemas",
    "docs:build": "zensical build --clean",
    "docs:serve": "zensical serve"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
