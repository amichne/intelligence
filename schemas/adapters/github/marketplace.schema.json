{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "github-marketplace.schema.json",
  "title": "GitHub Copilot Plugin Marketplace",
  "description": "GitHub Copilot CLI adapter marketplace catalog projection.",
  "type": "object",
  "required": [
    "name",
    "owner",
    "plugins"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor autocomplete."
    },
    "name": {
      "$ref": "#/$defs/name"
    },
    "owner": {
      "$ref": "#/$defs/person"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "pluginRoot": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "examples": [
        "frontend-design"
      ]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\./)?(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "pathOrPaths": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "person": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "pluginEntry": {
      "type": "object",
      "required": [
        "name",
        "source"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "source": {
          "$ref": "#/$defs/pluginSource"
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "$ref": "#/$defs/person"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "$ref": "#/$defs/stringList"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "commands": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "agents": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "skills": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "hooks": {
          "$ref": "#/$defs/hooksReference"
        },
        "mcpServers": {
          "$ref": "#/$defs/pathArrayOrObject"
        },
        "lspServers": {
          "$ref": "#/$defs/pathArrayOrObject"
        },
        "strict": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "pluginSource": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/githubSource"
        },
        {
          "$ref": "#/$defs/gitUrlSource"
        },
        {
          "$ref": "#/$defs/gitSubdirSource"
        }
      ]
    },
    "githubSource": {
      "type": "object",
      "required": [
        "source",
        "repo"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "github"
          ]
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "gitUrlSource": {
      "type": "object",
      "required": [
        "source",
        "url"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "url"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "gitSubdirSource": {
      "type": "object",
      "required": [
        "source",
        "url",
        "path"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "git-subdir"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "hooksReference": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "$ref": "github-hooks.schema.json#/$defs/hooks"
        }
      ]
    },
    "pathArrayOrObject": {
      "oneOf": [
        {
          "$ref": "#/$defs/pathOrPaths"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "examples": [
    {
      "$schema": "github-marketplace.schema.json",
      "name": "my-marketplace",
      "owner": {
        "name": "Your Organization",
        "email": "plugins@example.com"
      },
      "metadata": {
        "description": "Curated plugins for our team",
        "version": "1.0.0"
      },
      "plugins": [
        {
          "name": "frontend-design",
          "description": "Create a professional-looking GUI.",
          "version": "2.1.0",
          "source": "./plugins/frontend-design"
        }
      ]
    }
  ]
}
