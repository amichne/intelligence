{
  "$id": "https://github.com/amichne/intelligence/schemas/adapters/github-copilot/plugin-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "description": {
      "maxLength": 1024,
      "minLength": 1,
      "type": "string"
    },
    "name": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "skills": {
      "const": "skills/"
    },
    "version": {
      "pattern": "^0\\.0\\.0-intelligence\\.sha[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "description",
    "name",
    "skills",
    "version"
  ],
  "title": "Minimal GitHub Copilot package plugin V1",
  "type": "object"
}
