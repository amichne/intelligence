{
  "$defs": {
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "plugin": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "const": "Productivity"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "policy": {
          "additionalProperties": false,
          "properties": {
            "authentication": {
              "const": "ON_INSTALL"
            },
            "installation": {
              "const": "AVAILABLE"
            }
          },
          "required": [
            "authentication",
            "installation"
          ],
          "type": "object"
        },
        "source": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "maxLength": 82,
              "pattern": "^\\./plugins/[a-z0-9]+(?:-[a-z0-9]+)*$",
              "type": "string"
            },
            "source": {
              "const": "local"
            }
          },
          "required": [
            "path",
            "source"
          ],
          "type": "object"
        }
      },
      "required": [
        "category",
        "name",
        "policy",
        "source"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/adapters/codex/marketplace-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "interface": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "$ref": "#/$defs/identifier"
        }
      },
      "required": [
        "displayName"
      ],
      "type": "object"
    },
    "name": {
      "$ref": "#/$defs/identifier"
    },
    "plugins": {
      "items": {
        "$ref": "#/$defs/plugin"
      },
      "maxItems": 512,
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "interface",
    "name",
    "plugins"
  ],
  "title": "Minimal Codex marketplace V1",
  "type": "object"
}
