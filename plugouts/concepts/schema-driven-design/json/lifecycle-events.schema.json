{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lifecycle-events.schema.json",
  "title": "LifecycleEvent",
  "$defs": {
    "TenantId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "InvoiceId": {
      "type": "string",
      "minLength": 1
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "INVOICE_CREATED"
          ]
        },
        "tenantId": {
          "$ref": "#/$defs/TenantId"
        },
        "invoiceId": {
          "$ref": "#/$defs/InvoiceId"
        }
      },
      "required": [
        "type",
        "tenantId",
        "invoiceId"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "INVOICE_CANCELLED"
          ]
        },
        "tenantId": {
          "$ref": "#/$defs/TenantId"
        },
        "invoiceId": {
          "$ref": "#/$defs/InvoiceId"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "type",
        "tenantId",
        "invoiceId",
        "reason"
      ],
      "additionalProperties": false
    }
  ]
}
