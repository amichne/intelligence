{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-runtime-activation-plan.schema.json",
  "title": "Intelligence Runtime Activation Plan",
  "description": "Generated dry-run activation plan for replacing scattered sources with canonical symlinks and activating runtime plugin surfaces.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "operations"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "RUNTIME_ACTIVATION_PLAN"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operation"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "operationType": {
      "type": "string",
      "enum": [
        "ACTIVATE_RUNTIME_LINK",
        "IMPORT_MARKETPLACE",
        "REPLACE_SOURCE_WITH_SYMLINK"
      ]
    },
    "operationStatus": {
      "type": "string",
      "enum": [
        "READY_FOR_MANUAL_IMPORT",
        "WAITING_APPROVAL",
        "WAITING_REVIEW"
      ]
    },
    "runtimeLinkStrategy": {
      "type": "string",
      "enum": [
        "MARKETPLACE_IMPORT",
        "SYMLINK_CHILDREN",
        "SYMLINK_FILE",
        "SYMLINK_TREE"
      ]
    },
    "collisionPolicy": {
      "type": "string",
      "enum": [
        "BACKUP_THEN_LINK",
        "FAIL_IF_EXISTS",
        "SKIP_EXISTING"
      ]
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "sourceTurnoffReadiness",
        "cleanupLedger",
        "runtimeLinks",
        "sourceRoots"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_INPUTS"
          ]
        },
        "sourceTurnoffReadiness": {
          "$ref": "#/$defs/path"
        },
        "cleanupLedger": {
          "$ref": "#/$defs/path"
        },
        "runtimeLinks": {
          "$ref": "#/$defs/path"
        },
        "sourceRoots": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "mode",
        "totalOperations",
        "waitingApproval",
        "waitingReview",
        "readyForManualImport",
        "runtimeMutationAllowed"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_SUMMARY"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "DRY_RUN_ONLY"
          ]
        },
        "totalOperations": {
          "type": "integer",
          "minimum": 0
        },
        "waitingApproval": {
          "type": "integer",
          "minimum": 0
        },
        "waitingReview": {
          "type": "integer",
          "minimum": 0
        },
        "readyForManualImport": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeMutationAllowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": [
        "type",
        "name",
        "operationType",
        "status",
        "sourcePath",
        "targetPath",
        "requiresApproval",
        "evidence",
        "steps"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_OPERATION"
          ]
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "operationType": {
          "$ref": "#/$defs/operationType"
        },
        "status": {
          "$ref": "#/$defs/operationStatus"
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "backupPath": {
          "$ref": "#/$defs/path"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "runtimeLinkStrategy": {
          "$ref": "#/$defs/runtimeLinkStrategy"
        },
        "primitiveTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/primitiveType"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "collisionPolicy": {
          "$ref": "#/$defs/collisionPolicy"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "operationType": {
                "enum": [
                  "ACTIVATE_RUNTIME_LINK",
                  "IMPORT_MARKETPLACE"
                ]
              }
            },
            "required": [
              "operationType"
            ]
          },
          "then": {
            "required": [
              "primitiveTypes"
            ]
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "type",
        "manifest",
        "status"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_EVIDENCE"
          ]
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "reviewEvidenceSha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": [
        "type",
        "description",
        "commandPreview"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_STEP"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "commandPreview": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
