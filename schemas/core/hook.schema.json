{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hook.schema.json",
  "title": "HOOK",
  "description": "Provider-agnostic hook asset. Provider event names and matcher syntax belong to adapter projection.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "HOOK"
      ],
      "examples": [
        "HOOK"
      ]
    },
    "source": {
      "$ref": "./reference-definitions.schema.json#/$defs/SourceReference"
    },
    "path": {
      "$ref": "./reference-definitions.schema.json#/$defs/RelativePath"
    },
    "name": {
      "$ref": "./reference-definitions.schema.json#/$defs/Name"
    },
    "version": {
      "$ref": "./reference-definitions.schema.json#/$defs/VersionConstraint"
    },
    "integrity": {
      "$ref": "./reference-definitions.schema.json#/$defs/Digest"
    },
    "dependsOn": {
      "type": "array",
      "description": "Other primitives required by this hook.",
      "items": {
        "$ref": "./reference-definitions.schema.json#/$defs/PrimitiveDependency"
      },
      "examples": [
        [
          {
            "type": "INSTRUCTION",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./"
            },
            "path": "instructions/evidence.md",
            "name": "evidence"
          }
        ]
      ]
    }
  },
  "required": [
    "type",
    "source",
    "path"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "HOOK",
      "source": {
        "type": "LOCAL_SOURCE",
        "path": "./"
      },
      "path": "hooks/evidence-report.json",
      "name": "evidence-report"
    }
  ]
}
