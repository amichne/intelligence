{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-runtime-activation-preflight.schema.json",
  "title": "Intelligence Runtime Activation Preflight",
  "description": "Generated filesystem preflight for the dry-run runtime activation plan.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "RUNTIME_ACTIVATION_PREFLIGHT_REPORT"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/preflightEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "operationType": {
      "type": "string",
      "enum": [
        "ACTIVATE_RUNTIME_LINK",
        "IMPORT_MARKETPLACE",
        "REPLACE_SOURCE_WITH_SYMLINK"
      ]
    },
    "preflightStatus": {
      "type": "string",
      "enum": [
        "ALREADY_ACTIVE",
        "BLOCKED",
        "READY_FOR_APPROVAL",
        "REVIEW_REQUIRED"
      ]
    },
    "pathKind": {
      "type": "string",
      "enum": [
        "DIRECTORY",
        "FILE",
        "MISSING",
        "OTHER",
        "SYMLINK",
        "VIRTUAL"
      ]
    },
    "childCollision": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourcePath",
        "targetPath",
        "targetKind"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_CHILD_COLLISION"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "targetKind": {
          "$ref": "#/$defs/pathKind"
        }
      },
      "additionalProperties": false
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "runtimeActivationPlan"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_PREFLIGHT_INPUTS"
          ]
        },
        "runtimeActivationPlan": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "totalEntries",
        "alreadyActive",
        "blocked",
        "readyForApproval",
        "reviewRequired",
        "runtimeMutationAllowed"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_PREFLIGHT_SUMMARY"
          ]
        },
        "totalEntries": {
          "type": "integer",
          "minimum": 0
        },
        "alreadyActive": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "readyForApproval": {
          "type": "integer",
          "minimum": 0
        },
        "reviewRequired": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeMutationAllowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "filesystemCheck": {
      "type": "object",
      "required": [
        "type",
        "path",
        "exists",
        "kind"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "FILESYSTEM_PATH_CHECK"
          ]
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "exists": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/pathKind"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "preflightEntry": {
      "type": "object",
      "required": [
        "type",
        "operationName",
        "operationType",
        "status",
        "source",
        "target",
        "reasons"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_PREFLIGHT_ENTRY"
          ]
        },
        "operationName": {
          "$ref": "#/$defs/name"
        },
        "operationType": {
          "$ref": "#/$defs/operationType"
        },
        "status": {
          "$ref": "#/$defs/preflightStatus"
        },
        "source": {
          "$ref": "#/$defs/filesystemCheck"
        },
        "target": {
          "$ref": "#/$defs/filesystemCheck"
        },
        "backup": {
          "$ref": "#/$defs/filesystemCheck"
        },
        "childCollisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/childCollision"
          },
          "minItems": 1
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
