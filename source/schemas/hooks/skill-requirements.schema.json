{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hook-skill-requirements.schema.json",
  "title": "Hook Skill Requirements",
  "description": "Configuration for a hook that reminds or requires an agent to read selected skill files before using other tools.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "mode",
    "skills"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "HOOK_SKILL_REQUIREMENTS"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "ADVISORY",
        "DENY"
      ]
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requiredSkill"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "requiredSkill": {
      "type": "object",
      "required": [
        "type",
        "id",
        "skillPath",
        "requireRead",
        "notes"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "REQUIRED_SKILL"
          ]
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "skillPath": {
          "$ref": "#/$defs/path"
        },
        "requireRead": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
