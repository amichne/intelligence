{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claude-marketplace.schema.json",
  "title": "Claude Code Marketplace",
  "description": "Claude Code adapter marketplace catalog projection.",
  "type": "object",
  "required": [
    "name",
    "owner",
    "plugins"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor autocomplete."
    },
    "name": {
      "$ref": "#/$defs/name"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "$ref": "#/$defs/person"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "pluginRoot": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "additionalProperties": false
    },
    "allowCrossMarketplaceDependenciesOn": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/name"
      },
      "uniqueItems": true
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "examples": [
        "company-tools"
      ]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\./(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "pathOrPaths": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      ]
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "person": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "pluginEntry": {
      "type": "object",
      "required": [
        "name",
        "source"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/pluginSource"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "$ref": "#/$defs/person"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "$ref": "#/$defs/stringList"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "strict": {
          "type": "boolean"
        },
        "dependencies": {
          "$ref": "#/$defs/dependencies"
        },
        "skills": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "commands": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "agents": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "hooks": {
          "$ref": "#/$defs/hooksReference"
        },
        "mcpServers": {
          "$ref": "#/$defs/pathArrayOrObject"
        },
        "lspServers": {
          "$ref": "#/$defs/pathArrayOrObject"
        },
        "outputStyles": {
          "$ref": "#/$defs/pathOrPaths"
        },
        "experimental": {
          "type": "object",
          "properties": {
            "themes": {
              "$ref": "#/$defs/pathOrPaths"
            },
            "monitors": {
              "$ref": "#/$defs/pathOrPaths"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "pluginSource": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "$ref": "#/$defs/githubSource"
        },
        {
          "$ref": "#/$defs/gitUrlSource"
        },
        {
          "$ref": "#/$defs/gitSubdirSource"
        },
        {
          "$ref": "#/$defs/npmSource"
        }
      ]
    },
    "githubSource": {
      "type": "object",
      "required": [
        "source",
        "repo"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "github"
          ]
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "gitUrlSource": {
      "type": "object",
      "required": [
        "source",
        "url"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "url"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "gitSubdirSource": {
      "type": "object",
      "required": [
        "source",
        "url",
        "path"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "git-subdir"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "$ref": "#/$defs/gitSha"
        }
      },
      "additionalProperties": false
    },
    "npmSource": {
      "type": "object",
      "required": [
        "source",
        "package"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "npm"
          ]
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "registry": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/name"
          },
          {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/name"
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "marketplace": {
                "$ref": "#/$defs/name"
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "uniqueItems": true
    },
    "hooksReference": {
      "oneOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        {
          "$ref": "claude-hooks.schema.json#/$defs/hooks"
        }
      ]
    },
    "pathArrayOrObject": {
      "oneOf": [
        {
          "$ref": "#/$defs/pathOrPaths"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "examples": [
    {
      "$schema": "claude-marketplace.schema.json",
      "name": "company-tools",
      "owner": {
        "name": "DevTools Team",
        "email": "devtools@example.com"
      },
      "plugins": [
        {
          "name": "deployment-tools",
          "source": {
            "source": "github",
            "repo": "company/deploy-plugin"
          },
          "description": "Deployment automation tools"
        }
      ]
    }
  ]
}
