{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-cleanup-ledger.schema.json",
  "title": "Intelligence Cleanup Ledger",
  "description": "Approval gate for future deletion, symlink replacement, or broken-link removal of scattered source paths.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "policy",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "CLEANUP_LEDGER"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cleanupEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "cleanupDecision": {
      "type": "string",
      "enum": [
        "DELETE_ORIGINAL",
        "REMOVE_BROKEN_SYMLINK",
        "REPLACE_WITH_SYMLINK"
      ]
    },
    "cleanupStatus": {
      "type": "string",
      "enum": [
        "APPROVED",
        "EXECUTED",
        "PROPOSED"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "cleanupReviewEvidence": {
      "oneOf": [
        {
          "$ref": "#/$defs/digestReviewEvidence"
        },
        {
          "$ref": "#/$defs/sourceReviewEvidence"
        }
      ]
    },
    "digestReviewEvidence": {
      "type": "object",
      "required": [
        "type",
        "manifest",
        "targetSha256",
        "decision"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "DIGEST_REVIEW_EVIDENCE"
          ]
        },
        "manifest": {
          "type": "string",
          "enum": [
            "manifests/digest-review-decisions.json"
          ]
        },
        "targetSha256": {
          "$ref": "#/$defs/sha256"
        },
        "decision": {
          "type": "string",
          "enum": [
            "COVERED_BY_CANONICAL"
          ]
        }
      },
      "additionalProperties": false
    },
    "sourceReviewEvidence": {
      "type": "object",
      "required": [
        "type",
        "manifest",
        "targetPrimitiveType",
        "targetName",
        "sourceSha256",
        "decision"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_REVIEW_EVIDENCE"
          ]
        },
        "manifest": {
          "type": "string",
          "enum": [
            "manifests/source-review-decisions.json"
          ]
        },
        "targetPrimitiveType": {
          "$ref": "#/$defs/primitiveType"
        },
        "targetName": {
          "$ref": "#/$defs/name"
        },
        "sourceSha256": {
          "$ref": "#/$defs/sha256"
        },
        "decision": {
          "type": "string",
          "enum": [
            "COVERED_BY_CANONICAL"
          ]
        }
      },
      "additionalProperties": false
    },
    "cleanupEntry": {
      "type": "object",
      "required": [
        "type",
        "sourceRoot",
        "sourcePath",
        "observedPath",
        "decision",
        "status",
        "verification",
        "rollback"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CLEANUP_ENTRY"
          ]
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "observedPath": {
          "$ref": "#/$defs/path"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "canonicalPath": {
          "$ref": "#/$defs/path"
        },
        "reviewEvidence": {
          "$ref": "#/$defs/cleanupReviewEvidence"
        },
        "decision": {
          "$ref": "#/$defs/cleanupDecision"
        },
        "status": {
          "$ref": "#/$defs/cleanupStatus"
        },
        "verification": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "REPLACE_WITH_SYMLINK"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "required": [
              "targetPath",
              "canonicalPath",
              "reviewEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "DELETE_ORIGINAL"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "required": [
              "canonicalPath",
              "reviewEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "REMOVE_BROKEN_SYMLINK"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "required": [
              "targetPath"
            ]
          }
        }
      ]
    }
  }
}
