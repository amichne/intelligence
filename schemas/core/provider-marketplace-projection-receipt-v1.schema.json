{
  "$defs": {
    "archive": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "size": {
          "maximum": 138412032,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "name",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "package": {
      "additionalProperties": false,
      "properties": {
        "adapterVersion": {
          "pattern": "^0\\.0\\.0-intelligence\\.sha[0-9a-f]{64}$",
          "type": "string"
        },
        "archive": {
          "$ref": "#/$defs/archive"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "pluginPath": {
          "maxLength": 80,
          "pattern": "^plugins/[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        },
        "projectionSha256": {
          "$ref": "#/$defs/digest"
        }
      },
      "required": [
        "adapterVersion",
        "archive",
        "name",
        "pluginPath",
        "projectionSha256"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/provider-marketplace-projection-receipt-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "generator": {
      "const": "intelligence-kotlin-v1"
    },
    "marketplaceId": {
      "$ref": "#/$defs/identifier"
    },
    "packages": {
      "items": {
        "$ref": "#/$defs/package"
      },
      "maxItems": 512,
      "minItems": 1,
      "type": "array"
    },
    "provider": {
      "enum": [
        "codex",
        "github-copilot"
      ]
    },
    "schemaVersion": {
      "const": 1
    },
    "snapshotId": {
      "$ref": "#/$defs/identifier"
    },
    "type": {
      "const": "INTELLIGENCE_PROVIDER_MARKETPLACE_PROJECTION"
    }
  },
  "required": [
    "generator",
    "marketplaceId",
    "packages",
    "provider",
    "schemaVersion",
    "snapshotId",
    "type"
  ],
  "title": "Portable Intelligence provider marketplace projection receipt V1",
  "type": "object"
}
