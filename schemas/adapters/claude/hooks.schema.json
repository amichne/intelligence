{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claude-hooks.schema.json",
  "title": "Claude Code Hooks Configuration",
  "description": "Claude Code adapter hook configuration for settings files, plugin hooks/hooks.json, or inline plugin hook blocks.",
  "type": "object",
  "required": [
    "hooks"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor autocomplete."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the hooks file."
    },
    "disableAllHooks": {
      "type": "boolean",
      "description": "Disable every hook in this configuration without deleting it."
    },
    "hooks": {
      "$ref": "#/$defs/hooks"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "hooks": {
      "type": "object",
      "description": "Hook event registrations grouped by Claude Code lifecycle event.",
      "minProperties": 1,
      "properties": {
        "Setup": {
          "$ref": "#/$defs/matcherGroups"
        },
        "UserPromptSubmit": {
          "$ref": "#/$defs/matcherGroups"
        },
        "UserPromptExpansion": {
          "$ref": "#/$defs/matcherGroups"
        },
        "SessionStart": {
          "$ref": "#/$defs/matcherGroups"
        },
        "SessionEnd": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PreToolUse": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PermissionRequest": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PermissionDenied": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PostToolUse": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PostToolUseFailure": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PostToolBatch": {
          "$ref": "#/$defs/matcherGroups"
        },
        "Notification": {
          "$ref": "#/$defs/matcherGroups"
        },
        "SubagentStart": {
          "$ref": "#/$defs/matcherGroups"
        },
        "SubagentStop": {
          "$ref": "#/$defs/matcherGroups"
        },
        "TaskCreated": {
          "$ref": "#/$defs/matcherGroups"
        },
        "TaskCompleted": {
          "$ref": "#/$defs/matcherGroups"
        },
        "Stop": {
          "$ref": "#/$defs/matcherGroups"
        },
        "StopFailure": {
          "$ref": "#/$defs/matcherGroups"
        },
        "TeammateIdle": {
          "$ref": "#/$defs/matcherGroups"
        },
        "InstructionsLoaded": {
          "$ref": "#/$defs/matcherGroups"
        },
        "ConfigChange": {
          "$ref": "#/$defs/matcherGroups"
        },
        "CwdChanged": {
          "$ref": "#/$defs/matcherGroups"
        },
        "FileChanged": {
          "$ref": "#/$defs/matcherGroups"
        },
        "WorktreeCreate": {
          "$ref": "#/$defs/matcherGroups"
        },
        "WorktreeRemove": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PreCompact": {
          "$ref": "#/$defs/matcherGroups"
        },
        "PostCompact": {
          "$ref": "#/$defs/matcherGroups"
        },
        "Elicitation": {
          "$ref": "#/$defs/matcherGroups"
        },
        "ElicitationResult": {
          "$ref": "#/$defs/matcherGroups"
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "PostToolUse": [
            {
              "matcher": "Write|Edit",
              "hooks": [
                {
                  "type": "command",
                  "command": "${CLAUDE_PLUGIN_ROOT}/scripts/format.sh"
                }
              ]
            }
          ]
        }
      ]
    },
    "matcherGroups": {
      "type": "array",
      "description": "Matcher groups for one Claude Code hook event.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matcherGroup"
      }
    },
    "matcherGroup": {
      "type": "object",
      "description": "Matcher group that decides when one or more hook handlers run.",
      "required": [
        "hooks"
      ],
      "properties": {
        "matcher": {
          "type": "string",
          "description": "Pattern matched against the event-specific matcher field."
        },
        "hooks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/hookHandler"
          }
        }
      },
      "additionalProperties": false
    },
    "hookHandler": {
      "oneOf": [
        {
          "$ref": "#/$defs/commandHandler"
        },
        {
          "$ref": "#/$defs/httpHandler"
        },
        {
          "$ref": "#/$defs/mcpToolHandler"
        },
        {
          "$ref": "#/$defs/promptHandler"
        },
        {
          "$ref": "#/$defs/agentHandler"
        }
      ]
    },
    "commandHandler": {
      "type": "object",
      "required": [
        "type",
        "command"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "command"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "if": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        },
        "shell": {
          "type": "string",
          "enum": [
            "bash",
            "powershell"
          ]
        },
        "async": {
          "type": "boolean"
        },
        "asyncRewake": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "httpHandler": {
      "type": "object",
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "http"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "if": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        },
        "headers": {
          "$ref": "#/$defs/stringMap"
        },
        "allowedEnvVars": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "mcpToolHandler": {
      "type": "object",
      "required": [
        "type",
        "server",
        "tool"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "mcp_tool"
          ]
        },
        "server": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "if": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "promptHandler": {
      "type": "object",
      "required": [
        "type",
        "prompt"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "prompt"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "if": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agentHandler": {
      "type": "object",
      "required": [
        "type",
        "prompt"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "agent"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "if": {
          "type": "string"
        },
        "timeout": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "stringMap": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "examples": [
    {
      "$schema": "claude-hooks.schema.json",
      "description": "Format edited files with a plugin script.",
      "hooks": {
        "PostToolUse": [
          {
            "matcher": "Write|Edit",
            "hooks": [
              {
                "type": "command",
                "command": "${CLAUDE_PLUGIN_ROOT}/scripts/format.sh",
                "timeout": 30,
                "statusMessage": "Formatting edited files"
              }
            ]
          }
        ]
      }
    }
  ]
}
