{
  "$defs": {
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "plugin": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "source": {
          "maxLength": 82,
          "pattern": "^\\./plugins/[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        },
        "strict": {
          "const": true
        },
        "version": {
          "pattern": "^0\\.0\\.0-intelligence\\.sha[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "name",
        "source",
        "strict",
        "version"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/adapters/github-copilot/marketplace-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "name": {
      "$ref": "#/$defs/identifier"
    },
    "owner": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "plugins": {
      "items": {
        "$ref": "#/$defs/plugin"
      },
      "maxItems": 512,
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "name",
    "owner",
    "plugins"
  ],
  "title": "Minimal GitHub Copilot marketplace V1",
  "type": "object"
}
