{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-discovered-primitives.schema.json",
  "title": "Intelligence Discovered Primitives",
  "description": "Generated inventory of local AI tooling primitives and duplicate evidence.",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "generator",
    "sourceManifest",
    "counts",
    "missingRoots",
    "brokenSymlinks",
    "nameCollisions",
    "digestDuplicates",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "string",
      "enum": [
        "scripts/inventory-primitives.py"
      ]
    },
    "sourceManifest": {
      "type": "string",
      "enum": [
        "manifests/source-roots.json"
      ]
    },
    "counts": {
      "$ref": "#/$defs/countMap"
    },
    "missingRoots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/missingRoot"
      }
    },
    "brokenSymlinks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/brokenSymlink"
      }
    },
    "nameCollisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nameCollision"
      }
    },
    "digestDuplicates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/digestDuplicate"
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inventoryEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "candidateReference": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourceRoot",
        "path",
        "resolvedPath"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "missingRoot": {
      "type": "object",
      "required": [
        "name",
        "path",
        "resolvedPath"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "brokenSymlink": {
      "type": "object",
      "required": [
        "sourceRoot",
        "sourceRootPath",
        "path",
        "observedPath",
        "target"
      ],
      "properties": {
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourceRootPath": {
          "$ref": "#/$defs/path"
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "observedPath": {
          "$ref": "#/$defs/path"
        },
        "target": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "nameCollision": {
      "type": "object",
      "required": [
        "key",
        "entries"
      ],
      "properties": {
        "key": {
          "type": "object",
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "$ref": "#/$defs/primitiveType"
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          },
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "digestDuplicate": {
      "type": "object",
      "required": [
        "sha256",
        "entries"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateReference"
          },
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "inventoryEntry": {
      "type": "object",
      "required": [
        "type",
        "name",
        "path",
        "entryFile",
        "sourceRoot",
        "sourceRootPath",
        "sourceRootRole",
        "observedPath",
        "resolvedPath",
        "sha256"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "expectedResources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          }
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "entryFile": {
          "$ref": "#/$defs/path"
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourceRootPath": {
          "$ref": "#/$defs/path"
        },
        "sourceRootRole": {
          "type": "string",
          "minLength": 1
        },
        "observedPath": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "symlink": {
          "type": "boolean"
        },
        "symlinkTarget": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    }
  }
}
