{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-promotions.schema.json",
  "title": "Intelligence Promotions",
  "description": "Ledger of primitives promoted into this repository without deleting originals.",
  "type": "object",
  "required": [
    "schemaVersion",
    "policy",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promotionEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "promotionSource": {
      "type": "object",
      "required": [
        "sourceRoot",
        "sourcePath",
        "sourceResolvedPath",
        "notes"
      ],
      "properties": {
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "sourceResolvedPath": {
          "$ref": "#/$defs/path"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "firstPartyHandling": {
      "type": "object",
      "required": [
        "provider",
        "policy",
        "sourceNames",
        "canonicalName"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "policy": {
          "type": "string",
          "enum": [
            "INTENTIONAL_LOCAL_REPLACEMENT",
            "RENAMED_AND_REWRITTEN"
          ]
        },
        "sourceNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "canonicalName": {
          "$ref": "#/$defs/name"
        }
      },
      "additionalProperties": false
    },
    "promotionEntry": {
      "type": "object",
      "required": [
        "type",
        "name",
        "canonicalPath",
        "sourceRoot",
        "sourcePath",
        "sourceResolvedPath",
        "status",
        "notes"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "canonicalPath": {
          "$ref": "#/$defs/path"
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "sourceResolvedPath": {
          "$ref": "#/$defs/path"
        },
        "supportingSources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promotionSource"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "PROMOTED"
          ]
        },
        "firstPartyHandling": {
          "$ref": "#/$defs/firstPartyHandling"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
