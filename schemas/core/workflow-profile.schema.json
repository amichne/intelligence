{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow-profile.schema.json",
  "title": "WORKFLOW_PROFILE",
  "description": "Installable workflow selection over existing marketplace plugins, hook adapters, and validation commands.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "name",
    "marketplaces",
    "plugins",
    "hooks",
    "validation"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "WORKFLOW_PROFILE"
      ],
      "examples": [
        "WORKFLOW_PROFILE"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ],
      "examples": [
        1
      ]
    },
    "name": {
      "$ref": "./reference-definitions.schema.json#/$defs/Name"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "Default repository workflow profile."
      ]
    },
    "marketplaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowMarketplace"
      },
      "minItems": 1
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "./reference-definitions.schema.json#/$defs/Name"
      },
      "uniqueItems": true
    },
    "hooks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowHook"
      }
    },
    "validation": {
      "$ref": "#/$defs/workflowValidation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "workflowMarketplace": {
      "type": "object",
      "required": [
        "type",
        "name",
        "provider",
        "source",
        "entrypoint",
        "scope"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "WORKFLOW_MARKETPLACE"
          ],
          "examples": [
            "WORKFLOW_MARKETPLACE"
          ]
        },
        "name": {
          "$ref": "./reference-definitions.schema.json#/$defs/Name"
        },
        "provider": {
          "type": "string",
          "enum": [
            "agents",
            "claude",
            "codex",
            "github-copilot",
            "local"
          ],
          "examples": [
            "codex"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "https://github.com/acme/agent-tools/tree/marketplace/codex"
          ]
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "examples": [
            ".agents/plugins/marketplace.json"
          ]
        },
        "scope": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "plugins in this workflow profile"
          ]
        }
      },
      "additionalProperties": false
    },
    "workflowHook": {
      "type": "object",
      "required": [
        "type",
        "name",
        "adapter"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "WORKFLOW_HOOK"
          ],
          "examples": [
            "WORKFLOW_HOOK"
          ]
        },
        "name": {
          "$ref": "./reference-definitions.schema.json#/$defs/Name"
        },
        "adapter": {
          "type": "string",
          "enum": [
            "claude",
            "codex",
            "github"
          ],
          "examples": [
            "codex"
          ]
        }
      },
      "additionalProperties": false
    },
    "workflowValidation": {
      "type": "object",
      "required": [
        "type",
        "commands"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "WORKFLOW_VALIDATION"
          ],
          "examples": [
            "WORKFLOW_VALIDATION"
          ]
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "examples": [
            [
              "node scripts/validate-manifests.mjs"
            ]
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "type": "WORKFLOW_PROFILE",
      "schemaVersion": 1,
      "name": "review-default",
      "description": "Default review workflow profile.",
      "marketplaces": [
        {
          "type": "WORKFLOW_MARKETPLACE",
          "name": "acme-tools",
          "provider": "codex",
          "source": "https://github.com/acme/agent-tools/tree/marketplace/codex",
          "entrypoint": ".agents/plugins/marketplace.json",
          "scope": "plugins in this workflow profile"
        }
      ],
      "plugins": [
        "review-stack"
      ],
      "hooks": [
        {
          "type": "WORKFLOW_HOOK",
          "name": "evidence-report",
          "adapter": "codex"
        }
      ],
      "validation": {
        "type": "WORKFLOW_VALIDATION",
        "commands": [
          "node scripts/validate-manifests.mjs"
        ]
      }
    }
  ]
}
