{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-primitive-audits.schema.json",
  "title": "Intelligence Primitive Audits",
  "description": "Durable quality decisions for promoted primitives, runtime activation, and cleanup readiness.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "policy",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "PRIMITIVE_AUDITS"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/primitiveAudit"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "auditDecision": {
      "type": "string",
      "enum": [
        "ACTIVATE_READY",
        "CLEANUP_READY",
        "DEFER",
        "IGNORE",
        "PROMOTE_READY",
        "REWRITE_FIRST",
        "SYNTHESIZE_FIRST"
      ]
    },
    "auditStatus": {
      "type": "string",
      "enum": [
        "BLOCKED",
        "NEEDS_WORK",
        "PASS"
      ]
    },
    "auditScope": {
      "type": "string",
      "enum": [
        "ACTIVATION",
        "CLEANUP",
        "PROMOTION",
        "REVIEW"
      ]
    },
    "evidenceKind": {
      "type": "string",
      "enum": [
        "COMMAND",
        "FILE",
        "GENERATED_REPORT",
        "MANUAL_REVIEW",
        "SCHEMA_VALIDATION"
      ]
    },
    "primitiveReference": {
      "type": "object",
      "required": [
        "type",
        "primitiveType",
        "name",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_REFERENCE"
          ]
        },
        "primitiveType": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "path": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "auditCriterion": {
      "type": "object",
      "required": [
        "type",
        "name",
        "status",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AUDIT_CRITERION"
          ]
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "status": {
          "$ref": "#/$defs/auditStatus"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "auditEvidence": {
      "type": "object",
      "required": [
        "type",
        "kind",
        "status",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AUDIT_EVIDENCE"
          ]
        },
        "kind": {
          "$ref": "#/$defs/evidenceKind"
        },
        "status": {
          "$ref": "#/$defs/auditStatus"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sourceRelationship": {
      "type": "string",
      "enum": [
        "FIRST_PARTY_SOURCE",
        "LEGACY_SOURCE",
        "RENAMED_DERIVATIVE",
        "RUNTIME_COPY",
        "SUPPORTING_SOURCE"
      ]
    },
    "sourceCandidate": {
      "type": "object",
      "required": [
        "type",
        "sourceRoot",
        "sourcePath",
        "resolvedPath",
        "relationship"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_CANDIDATE"
          ]
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        },
        "relationship": {
          "$ref": "#/$defs/sourceRelationship"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "primitiveAudit": {
      "type": "object",
      "required": [
        "type",
        "primitive",
        "scope",
        "decision",
        "criteria",
        "evidence",
        "notes"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_AUDIT"
          ]
        },
        "primitive": {
          "$ref": "#/$defs/primitiveReference"
        },
        "scope": {
          "$ref": "#/$defs/auditScope"
        },
        "decision": {
          "$ref": "#/$defs/auditDecision"
        },
        "criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditCriterion"
          },
          "minItems": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditEvidence"
          },
          "minItems": 1
        },
        "sourceCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceCandidate"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
