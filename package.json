{
  "name": "intelligence",
  "private": true,
  "scripts": {
    "intelligence": "python3 scripts/intelligence.py",
    "package:cli": "python3 scripts/package-intelligence.py --out dist",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "marketplace:materialize": "python3 scripts/publish-marketplace.py materialize --provider codex --out /tmp/intelligence-codex-marketplace",
    "marketplace:materialize:github": "python3 scripts/publish-marketplace.py materialize --provider github --out /tmp/intelligence-github-marketplace",
    "marketplace:sync-main": "python3 scripts/publish-marketplace.py sync-main-marketplaces",
    "marketplace:sync-main:check": "python3 scripts/publish-marketplace.py sync-main-marketplaces --check",
    "marketplace:publish:preview": "python3 scripts/publish-marketplace.py publish-branch --provider codex --branch codex --no-push",
    "marketplace:publish:github:preview": "python3 scripts/publish-marketplace.py publish-branch --provider github --branch github --no-push",
    "schema:policy": "node skills/manage-json-schemas/scripts/schema-contracts.js policy-tree --root skills/manage-json-schemas/references/schemas",
    "docs:build": "zensical build --clean",
    "docs:serve": "zensical serve"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
