{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex-marketplace-lock.schema.json",
  "title": "Codex Marketplace Hydration Lock",
  "description": "Generated evidence describing the source references copied into a hydrated Codex marketplace branch.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedAt",
    "sourceSha",
    "plugins"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "HYDRATED_MARKETPLACE"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\./).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "plugin": {
      "type": "object",
      "required": [
        "name",
        "version",
        "sourceManifest",
        "references"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "sourceManifest": {
          "$ref": "#/$defs/relativePath"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "reference": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourcePath",
        "targetPath",
        "sha256"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AGENT",
            "HOOK",
            "INSTRUCTION",
            "SKILL"
          ]
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourcePath": {
          "$ref": "#/$defs/relativePath"
        },
        "targetPath": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    }
  }
}
