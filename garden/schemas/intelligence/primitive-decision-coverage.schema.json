{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-primitive-decision-coverage.schema.json",
  "title": "Intelligence Primitive Decision Coverage",
  "description": "Generated per-entry decision coverage report for discovered AI tooling primitives.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "PRIMITIVE_DECISION_COVERAGE_REPORT"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "coverageState": {
      "type": "string",
      "enum": [
        "CANONICAL_OWNER",
        "CANONICAL_RUNTIME_ALIAS",
        "DIGEST_REVIEW_DECISION",
        "SOURCE_REVIEW_DECISION",
        "SOURCE_ROOT_DECISION",
        "UNREVIEWED_SINGLETON"
      ]
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "discoveredPrimitives",
        "consolidationReport",
        "sourceReviewDecisions",
        "digestReviewDecisions",
        "sourceRootDecisions"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_DECISION_COVERAGE_INPUTS"
          ]
        },
        "discoveredPrimitives": {
          "$ref": "#/$defs/path"
        },
        "consolidationReport": {
          "$ref": "#/$defs/path"
        },
        "sourceReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "digestReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "sourceRootDecisions": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "totalEntries",
        "canonicalOwner",
        "canonicalRuntimeAlias",
        "sourceReviewDecision",
        "digestReviewDecision",
        "sourceRootDecision",
        "unreviewedSingleton",
        "allEntriesCovered",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_DECISION_COVERAGE_SUMMARY"
          ]
        },
        "totalEntries": {
          "type": "integer",
          "minimum": 0
        },
        "canonicalOwner": {
          "type": "integer",
          "minimum": 0
        },
        "canonicalRuntimeAlias": {
          "type": "integer",
          "minimum": 0
        },
        "sourceReviewDecision": {
          "type": "integer",
          "minimum": 0
        },
        "digestReviewDecision": {
          "type": "integer",
          "minimum": 0
        },
        "sourceRootDecision": {
          "type": "integer",
          "minimum": 0
        },
        "unreviewedSingleton": {
          "type": "integer",
          "minimum": 0
        },
        "allEntriesCovered": {
          "type": "boolean"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": [
        "type",
        "primitive",
        "sourceRoot",
        "sourceRootRole",
        "path",
        "sha256",
        "coverageState",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_DECISION_COVERAGE_ENTRY"
          ]
        },
        "primitive": {
          "$ref": "#/$defs/primitiveReference"
        },
        "sourceRoot": {
          "$ref": "#/$defs/name"
        },
        "sourceRootRole": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "coverageState": {
          "$ref": "#/$defs/coverageState"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "primitiveReference": {
      "type": "object",
      "required": [
        "type",
        "primitiveType",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "PRIMITIVE_REFERENCE"
          ]
        },
        "primitiveType": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "$ref": "#/$defs/name"
        }
      },
      "additionalProperties": false
    }
  }
}
