{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-source-review-decisions.schema.json",
  "title": "Intelligence Source Review Decisions",
  "description": "Durable review decisions for generated duplicate-name source groups before trimming, promotion, or cleanup.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "policy",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "SOURCE_REVIEW_DECISIONS"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceReviewDecision"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "reviewDecision": {
      "type": "string",
      "enum": [
        "COVERED_BY_CANONICAL",
        "DEFER",
        "KEEP_CANONICAL",
        "RETAIN_EXTERNAL",
        "REVIEW_REQUIRED",
        "REWRITE_FIRST"
      ]
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "DECIDED",
        "NEEDS_REVIEW"
      ]
    },
    "queueType": {
      "type": "string",
      "enum": [
        "NAME_REVIEW"
      ]
    },
    "generatedAction": {
      "type": "string",
      "enum": [
        "DEDUP_IDENTICAL_NAME",
        "RECONCILE_RUNTIME_COPY",
        "SYNTHESIZE"
      ]
    },
    "sourceReviewTarget": {
      "type": "object",
      "required": [
        "type",
        "primitiveType",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_REVIEW_TARGET"
          ]
        },
        "primitiveType": {
          "$ref": "#/$defs/primitiveType"
        },
        "name": {
          "$ref": "#/$defs/name"
        }
      },
      "additionalProperties": false
    },
    "queueEvidence": {
      "type": "object",
      "required": [
        "type",
        "queueType",
        "generatedAction",
        "priority",
        "entryCount",
        "buckets",
        "sourceRoots",
        "sourceDigests"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "QUEUE_EVIDENCE"
          ]
        },
        "queueType": {
          "$ref": "#/$defs/queueType"
        },
        "generatedAction": {
          "$ref": "#/$defs/generatedAction"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "entryCount": {
          "type": "integer",
          "minimum": 2
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "sourceRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "sourceDigests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sha256"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "canonicalCoverage": {
      "type": "object",
      "required": [
        "type",
        "path",
        "notes"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CANONICAL_COVERAGE"
          ]
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sourceReviewDecision": {
      "type": "object",
      "required": [
        "type",
        "target",
        "decision",
        "status",
        "queueEvidence",
        "rationale",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_REVIEW_DECISION"
          ]
        },
        "target": {
          "$ref": "#/$defs/sourceReviewTarget"
        },
        "decision": {
          "$ref": "#/$defs/reviewDecision"
        },
        "status": {
          "$ref": "#/$defs/reviewStatus"
        },
        "queueEvidence": {
          "$ref": "#/$defs/queueEvidence"
        },
        "canonicalCoverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonicalCoverage"
          },
          "minItems": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
