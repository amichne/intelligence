{
  "$defs": {
    "file": {
      "additionalProperties": false,
      "properties": {
        "executable": {
          "type": "boolean"
        },
        "path": {
          "maxLength": 240,
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//)(?!.*\\\\)(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "maximum": 16777216,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "executable",
        "path",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "primaryFile": {
      "additionalProperties": false,
      "properties": {
        "executable": {
          "const": false
        },
        "path": {
          "maxLength": 240,
          "minLength": 1,
          "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*/SKILL\\.md$",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "maximum": 16777216,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "executable",
        "path",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "skill": {
      "additionalProperties": false,
      "properties": {
        "assets": {
          "items": {
            "$ref": "#/$defs/file"
          },
          "maxItems": 4094,
          "type": "array"
        },
        "description": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "primary": {
          "$ref": "#/$defs/primaryFile"
        }
      },
      "required": [
        "assets",
        "description",
        "name",
        "primary"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/portable-package-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "description": {
      "maxLength": 1024,
      "minLength": 1,
      "type": "string"
    },
    "marketplaceId": {
      "$ref": "#/$defs/identifier"
    },
    "name": {
      "$ref": "#/$defs/identifier"
    },
    "schemaVersion": {
      "const": 1
    },
    "skills": {
      "items": {
        "$ref": "#/$defs/skill"
      },
      "maxItems": 512,
      "minItems": 1,
      "type": "array"
    },
    "tags": {
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "type": "array",
      "uniqueItems": true
    },
    "type": {
      "const": "INTELLIGENCE_PACKAGE"
    }
  },
  "required": [
    "description",
    "marketplaceId",
    "name",
    "schemaVersion",
    "skills",
    "tags",
    "type"
  ],
  "title": "Portable Intelligence package V1",
  "type": "object"
}
