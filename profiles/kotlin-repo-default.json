{
  "type": "WORKFLOW_PROFILE",
  "schemaVersion": 1,
  "name": "kotlin-repo-default",
  "description": "Default Kotlin repository workflow using typed design discipline, Kotlin correctness, evidence-driven delivery, and Codex hook adapters.",
  "marketplaces": [
    {
      "type": "WORKFLOW_MARKETPLACE",
      "name": "amichne-intelligence",
      "provider": "codex",
      "source": "https://github.com/amichne/intelligence/tree/main",
      "entrypoint": "codex/marketplace.json",
      "scope": "plugins in this workflow profile"
    }
  ],
  "plugins": [
    "typed-design-discipline",
    "kotlin-correctness",
    "evidence-driven-delivery"
  ],
  "hooks": [
    {
      "type": "WORKFLOW_HOOK",
      "name": "agents-md-turn-refresh",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "required-skill-read",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "kotlin-horizontalization-check",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "gradle-check-green",
      "adapter": "codex"
    }
  ],
  "validation": {
    "type": "WORKFLOW_VALIDATION",
    "commands": [
      "node scripts/validate-manifests.mjs"
    ]
  }
}
