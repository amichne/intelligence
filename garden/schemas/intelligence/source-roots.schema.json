{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-source-roots.schema.json",
  "title": "Intelligence Source Roots",
  "description": "Hand-authored scan boundary for local AI primitive discovery.",
  "type": "object",
  "required": [
    "schemaVersion",
    "purpose",
    "scanRoots",
    "excludedPathParts",
    "excludeGlobs",
    "classificationRules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "scanRoots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "role"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "backup-source",
              "canonical-candidate",
              "local-repo-source",
              "runtime-source"
            ]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "excludedPathParts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "excludeGlobs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "classificationRules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
