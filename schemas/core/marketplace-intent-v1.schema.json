{
  "$defs": {
    "githubSource": {
      "additionalProperties": false,
      "properties": {
        "repository": {
          "maxLength": 180,
          "pattern": "^(?!.*\\.git$)https://github\\.com/[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?/[a-z0-9](?:[a-z0-9._-]{0,98}[a-z0-9])?$",
          "type": "string"
        },
        "tag": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "const": "GITHUB_RELEASE"
        }
      },
      "required": [
        "repository",
        "tag",
        "type"
      ],
      "type": "object"
    },
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "localSource": {
      "additionalProperties": false,
      "properties": {
        "indexSha256": {
          "$ref": "#/$defs/sha256"
        },
        "path": {
          "maxLength": 240,
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//)(?!.*\\\\)(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "type": {
          "const": "LOCAL_SNAPSHOT"
        }
      },
      "required": [
        "indexSha256",
        "path",
        "type"
      ],
      "type": "object"
    },
    "selection": {
      "additionalProperties": false,
      "properties": {
        "marketplaceId": {
          "$ref": "#/$defs/identifier"
        },
        "packages": {
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "maxItems": 512,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "source": {
          "oneOf": [
            {
              "$ref": "#/$defs/githubSource"
            },
            {
              "$ref": "#/$defs/localSource"
            }
          ]
        }
      },
      "required": [
        "marketplaceId",
        "packages",
        "source"
      ],
      "type": "object"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/marketplace-intent-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "selections": {
      "items": {
        "$ref": "#/$defs/selection"
      },
      "maxItems": 128,
      "minItems": 1,
      "type": "array"
    },
    "type": {
      "const": "MARKETPLACE_INTENT"
    }
  },
  "required": [
    "schemaVersion",
    "selections",
    "type"
  ],
  "title": "Portable Intelligence marketplace intent V1",
  "type": "object"
}
