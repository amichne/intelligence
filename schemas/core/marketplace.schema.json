{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "marketplace.schema.json",
  "title": "MARKETPLACE",
  "description": "Provider-neutral marketplace catalog contract.",
  "$ref": "./reference-definitions.schema.json#/$defs/Marketplace",
  "examples": [
    {
      "type": "MARKETPLACE",
      "schemaVersion": 1,
      "name": "acme-tools",
      "owner": {
        "name": "Platform Team",
        "email": "platform@example.com"
      },
      "description": "Approved agent assets for product engineering.",
      "management": {
        "type": "MANAGEMENT_POLICY",
        "mode": "MANAGED",
        "allowExternalMarketplaces": [
          "shared-tools"
        ]
      },
      "plugins": [
        {
          "type": "PLUGIN_ENTRY",
          "name": "review-stack",
          "plugin": {
            "type": "PLUGIN_REFERENCE",
            "name": "review-stack",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./plugins/review-stack"
            },
            "version": "0.1.0"
          },
          "tags": [
            "review",
            "quality"
          ]
        }
      ],
      "skills": [
        {
          "type": "SKILL",
          "source": {
            "type": "GITHUB_SOURCE",
            "repo": "acme/shared-skills",
            "ref": "v1.4.0"
          },
          "path": "skills/code-review",
          "name": "code-review"
        }
      ],
      "agents": [],
      "instructions": [],
      "hooks": []
    }
  ]
}
