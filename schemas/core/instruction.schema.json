{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "instruction.schema.json",
  "title": "INSTRUCTION",
  "description": "A reusable instruction document.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "INSTRUCTION"
      ],
      "examples": [
        "INSTRUCTION"
      ]
    },
    "source": {
      "$ref": "./reference-definitions.schema.json#/$defs/SourceReference"
    },
    "path": {
      "$ref": "./reference-definitions.schema.json#/$defs/RelativePath"
    },
    "name": {
      "$ref": "./reference-definitions.schema.json#/$defs/Name"
    },
    "version": {
      "$ref": "./reference-definitions.schema.json#/$defs/VersionConstraint"
    },
    "integrity": {
      "$ref": "./reference-definitions.schema.json#/$defs/Digest"
    }
  },
  "required": [
    "type",
    "source",
    "path"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "INSTRUCTION",
      "source": {
        "type": "LOCAL_SOURCE",
        "path": "./"
      },
      "path": "instructions/type-safety.md",
      "name": "type-safety"
    }
  ]
}
