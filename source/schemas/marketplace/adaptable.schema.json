{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adaptable-marketplace.schema.json",
  "title": "ADAPTABLE_MARKETPLACE",
  "description": "Provider-neutral marketplace catalog that can be adapted into runtime-native marketplace branches.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "MARKETPLACE"
      ],
      "examples": [
        "MARKETPLACE"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ],
      "examples": [
        1
      ]
    },
    "name": {
      "$ref": "reference-definitions.schema.json#/$defs/Name"
    },
    "owner": {
      "$ref": "reference-definitions.schema.json#/$defs/Owner"
    },
    "description": {
      "type": "string",
      "description": "Marketplace description.",
      "minLength": 1,
      "examples": [
        "Approved agent assets for product engineering."
      ]
    },
    "management": {
      "$ref": "reference-definitions.schema.json#/$defs/ManagementPolicy"
    },
    "plugins": {
      "type": "array",
      "description": "Plugin entries exposed by this marketplace.",
      "items": {
        "$ref": "reference-definitions.schema.json#/$defs/PluginEntry"
      },
      "examples": [
        [
          {
            "type": "PLUGIN_ENTRY",
            "name": "review-stack",
            "plugin": {
              "type": "PLUGIN_REFERENCE",
              "name": "review-stack",
              "source": {
                "type": "LOCAL_SOURCE",
                "path": "./plugins/review-stack"
              }
            }
          }
        ]
      ]
    },
    "skills": {
      "type": "array",
      "description": "Standalone skill primitives exposed by this marketplace.",
      "items": {
        "$ref": "skill.schema.json"
      },
      "examples": [
        [
          {
            "type": "SKILL",
            "source": {
              "type": "GITHUB_SOURCE",
              "repo": "acme/shared-skills",
              "ref": "v1.4.0"
            },
            "path": "skills/code-review",
            "name": "code-review"
          }
        ]
      ]
    },
    "agents": {
      "type": "array",
      "description": "Standalone agent primitives exposed by this marketplace.",
      "items": {
        "$ref": "agent.schema.json"
      },
      "examples": [
        [
          {
            "type": "AGENT",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./"
            },
            "path": "agents/reviewer.md",
            "name": "reviewer"
          }
        ]
      ]
    },
    "instructions": {
      "type": "array",
      "description": "Standalone instruction primitives exposed by this marketplace.",
      "items": {
        "$ref": "instruction.schema.json"
      },
      "examples": [
        [
          {
            "type": "INSTRUCTION",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./"
            },
            "path": "instructions/type-safety.md",
            "name": "type-safety"
          }
        ]
      ]
    },
    "hooks": {
      "type": "array",
      "description": "Standalone hook primitives exposed by this marketplace.",
      "items": {
        "$ref": "hook.schema.json"
      },
      "examples": [
        [
          {
            "type": "HOOK",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./"
            },
            "path": "hooks/evidence-report.json",
            "name": "evidence-report"
          }
        ]
      ]
    },
    "metadata": {
      "$ref": "reference-definitions.schema.json#/$defs/StringMap"
    }
  },
  "required": [
    "type",
    "schemaVersion",
    "name",
    "owner",
    "plugins"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "MARKETPLACE",
      "schemaVersion": 1,
      "name": "acme-tools",
      "owner": {
        "name": "Platform Team",
        "email": "platform@example.com"
      },
      "description": "Approved agent assets for product engineering.",
      "management": {
        "type": "MANAGEMENT_POLICY",
        "mode": "MANAGED",
        "allowExternalMarketplaces": [
          "shared-tools"
        ]
      },
      "plugins": [
        {
          "type": "PLUGIN_ENTRY",
          "name": "review-stack",
          "plugin": {
            "type": "PLUGIN_REFERENCE",
            "name": "review-stack",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./plugins/review-stack"
            },
            "version": "0.1.0"
          },
          "description": "Review workflow plugin family.",
          "tags": [
            "review",
            "quality"
          ]
        }
      ],
      "skills": [],
      "agents": [],
      "instructions": [],
      "hooks": []
    }
  ]
}
