{
  "$defs": {
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "file": {
      "additionalProperties": false,
      "properties": {
        "backupPath": {
          "$ref": "#/$defs/transactionPath"
        },
        "newSha256": {
          "$ref": "#/$defs/digest"
        },
        "oldSha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "path": {
          "enum": [
            ".intelligence/adaptable.marketplace.json",
            ".intelligence/marketplace-lock.json"
          ]
        },
        "stagedPath": {
          "$ref": "#/$defs/transactionPath"
        }
      },
      "required": [
        "backupPath",
        "newSha256",
        "oldSha256",
        "path",
        "stagedPath"
      ],
      "type": "object"
    },
    "transactionPath": {
      "maxLength": 320,
      "pattern": "^\\.intelligence/\\.marketplace-transactions/[0-9a-f]{64}/[A-Za-z0-9._-]+\\.(?:new|old)$",
      "type": "string"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/marketplace-transaction-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "files": {
      "items": {
        "$ref": "#/$defs/file"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "schemaVersion": {
      "const": 1
    },
    "transactionId": {
      "$ref": "#/$defs/digest"
    },
    "type": {
      "const": "MARKETPLACE_TRANSACTION"
    }
  },
  "required": [
    "files",
    "schemaVersion",
    "transactionId",
    "type"
  ],
  "title": "Portable Intelligence marketplace transaction journal V1",
  "type": "object"
}
