{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent.schema.json",
  "title": "AGENT",
  "description": "A reusable agent definition.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "AGENT"
      ],
      "examples": [
        "AGENT"
      ]
    },
    "source": {
      "$ref": "./reference-definitions.schema.json#/$defs/SourceReference"
    },
    "path": {
      "$ref": "./reference-definitions.schema.json#/$defs/RelativePath"
    },
    "name": {
      "$ref": "./reference-definitions.schema.json#/$defs/Name"
    },
    "version": {
      "$ref": "./reference-definitions.schema.json#/$defs/VersionConstraint"
    },
    "integrity": {
      "$ref": "./reference-definitions.schema.json#/$defs/Digest"
    },
    "dependsOn": {
      "type": "array",
      "description": "Other primitives required by this agent.",
      "items": {
        "$ref": "./reference-definitions.schema.json#/$defs/PrimitiveDependency"
      },
      "examples": [
        [
          {
            "type": "SKILL",
            "source": {
              "type": "LOCAL_SOURCE",
              "path": "./"
            },
            "path": "skills/code-review",
            "name": "code-review"
          }
        ]
      ]
    }
  },
  "required": [
    "type",
    "source",
    "path"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "AGENT",
      "source": {
        "type": "LOCAL_SOURCE",
        "path": "./"
      },
      "path": "agents/reviewer.md",
      "name": "reviewer"
    }
  ]
}
