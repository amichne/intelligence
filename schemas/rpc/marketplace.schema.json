{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "marketplace-rpc.schema.json",
  "title": "MARKETPLACE_RPC",
  "description": "JSON-RPC 2.0 stdio contract for Intelligence marketplace and validation operations.",
  "oneOf": [
    {
      "$ref": "#/$defs/RpcRequest"
    },
    {
      "$ref": "#/$defs/RpcResponse"
    }
  ],
  "$defs": {
    "RpcId": {
      "description": "Request/response correlation identifier. Notifications are not supported in v1.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer"
        }
      ],
      "examples": [
        "browse-1",
        1
      ]
    },
    "RpcRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "method",
        "params"
      ],
      "properties": {
        "jsonrpc": {
          "type": "string",
          "enum": [
            "2.0"
          ]
        },
        "id": {
          "$ref": "#/$defs/RpcId"
        },
        "method": {
          "$ref": "#/$defs/Method"
        },
        "params": {
          "$ref": "#/$defs/Params"
        }
      },
      "examples": [
        {
          "jsonrpc": "2.0",
          "id": "browse-slopsentral",
          "method": "marketplace.browse",
          "params": {
            "repository": "amichne/slopsentral",
            "provider": "auto"
          }
        }
      ]
    },
    "RpcResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id"
      ],
      "properties": {
        "jsonrpc": {
          "type": "string",
          "enum": [
            "2.0"
          ]
        },
        "id": {
          "$ref": "#/$defs/RpcId"
        },
        "result": {
          "type": "object"
        },
        "error": {
          "$ref": "#/$defs/RpcError"
        }
      },
      "oneOf": [
        {
          "required": [
            "result"
          ],
          "not": {
            "required": [
              "error"
            ]
          }
        },
        {
          "required": [
            "error"
          ],
          "not": {
            "required": [
              "result"
            ]
          }
        }
      ]
    },
    "RpcError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "data"
      ],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "PARSE_ERROR",
                "INVALID_REQUEST",
                "METHOD_NOT_FOUND",
                "INVALID_PARAMS",
                "MARKETPLACE_FAILURE",
                "VALIDATION_FAILURE",
                "INTERNAL_ERROR"
              ]
            },
            "exitCode": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "Method": {
      "type": "string",
      "enum": [
        "marketplace.browse",
        "marketplace.remotes.list",
        "marketplace.remotes.add",
        "marketplace.remotes.remove",
        "marketplace.import",
        "marketplace.install",
        "marketplace.materialize",
        "marketplace.publishDefault",
        "marketplace.publishBranch",
        "validation.run"
      ]
    },
    "Params": {
      "oneOf": [
        {
          "$ref": "#/$defs/BrowseParams"
        },
        {
          "$ref": "#/$defs/RepoParams"
        },
        {
          "$ref": "#/$defs/AddRemoteParams"
        },
        {
          "$ref": "#/$defs/RemoveRemoteParams"
        },
        {
          "$ref": "#/$defs/ImportParams"
        },
        {
          "$ref": "#/$defs/InstallParams"
        },
        {
          "$ref": "#/$defs/MaterializeParams"
        },
        {
          "$ref": "#/$defs/PublishBranchParams"
        },
        {
          "$ref": "#/$defs/ValidationParams"
        }
      ]
    },
    "Provider": {
      "type": "string",
      "enum": [
        "all",
        "codex",
        "github",
        "copilot"
      ]
    },
    "BrowseProvider": {
      "type": "string",
      "enum": [
        "auto",
        "codex",
        "github",
        "copilot",
        "source"
      ]
    },
    "PathString": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "/Users/amichne/code/intelligence"
      ]
    },
    "RepositoryReference": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "amichne/slopsentral",
        "https://github.com/amichne/slopsentral",
        "/Users/amichne/code/slopsentral"
      ]
    },
    "BrowseParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/RepositoryReference"
        },
        "provider": {
          "$ref": "#/$defs/BrowseProvider"
        }
      }
    },
    "RepoParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        }
      }
    },
    "AddRemoteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "name",
        "repository"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "$ref": "#/$defs/RepositoryReference"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "RemoveRemoteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "name"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ImportParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "target"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "slopsentral/kotlin-engineering"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "InstallParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "repository"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "repository": {
          "$ref": "#/$defs/RepositoryReference"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "MaterializeParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "outRoot",
        "provider"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "outRoot": {
          "$ref": "#/$defs/PathString"
        },
        "provider": {
          "$ref": "#/$defs/Provider"
        }
      }
    },
    "PublishBranchParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "provider",
        "noPush"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "provider": {
          "$ref": "#/$defs/Provider"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "noPush": {
          "type": "boolean"
        }
      }
    },
    "ValidationParams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoRoot",
        "portable"
      ],
      "properties": {
        "repoRoot": {
          "$ref": "#/$defs/PathString"
        },
        "portable": {
          "type": "boolean"
        },
        "hydrated": {
          "$ref": "#/$defs/PathString"
        }
      }
    }
  }
}
