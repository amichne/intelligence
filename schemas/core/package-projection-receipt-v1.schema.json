{
  "$defs": {
    "archive": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "size": {
          "maximum": 138412032,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "name",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "file": {
      "additionalProperties": false,
      "properties": {
        "executable": {
          "type": "boolean"
        },
        "generatedPath": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "size": {
          "maximum": 16777216,
          "minimum": 0,
          "type": "integer"
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        }
      },
      "required": [
        "executable",
        "generatedPath",
        "sha256",
        "size",
        "sourcePath"
      ],
      "type": "object"
    },
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "path": {
      "maxLength": 240,
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//)(?!.*\\\\)(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "skill": {
      "additionalProperties": false,
      "properties": {
        "generatedPath": {
          "$ref": "#/$defs/path"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        }
      },
      "required": [
        "generatedPath",
        "name",
        "sourcePath"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/package-projection-receipt-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adapterVersion": {
      "pattern": "^0\\.0\\.0-intelligence\\.sha[0-9a-f]{64}$",
      "type": "string"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/file"
      },
      "maxItems": 4095,
      "minItems": 1,
      "type": "array"
    },
    "generator": {
      "const": "intelligence-kotlin-v1"
    },
    "marketplaceId": {
      "$ref": "#/$defs/identifier"
    },
    "packageArchive": {
      "$ref": "#/$defs/archive"
    },
    "packageName": {
      "$ref": "#/$defs/identifier"
    },
    "provider": {
      "enum": [
        "codex",
        "github-copilot"
      ]
    },
    "schemaVersion": {
      "const": 1
    },
    "skills": {
      "items": {
        "$ref": "#/$defs/skill"
      },
      "maxItems": 512,
      "minItems": 1,
      "type": "array"
    },
    "snapshotId": {
      "$ref": "#/$defs/identifier"
    },
    "type": {
      "const": "INTELLIGENCE_PACKAGE_PROJECTION"
    }
  },
  "required": [
    "adapterVersion",
    "files",
    "generator",
    "marketplaceId",
    "packageArchive",
    "packageName",
    "provider",
    "schemaVersion",
    "skills",
    "snapshotId",
    "type"
  ],
  "title": "Portable Intelligence package projection receipt V1",
  "type": "object"
}
