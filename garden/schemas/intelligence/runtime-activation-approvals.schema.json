{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-runtime-activation-approvals.schema.json",
  "title": "Intelligence Runtime Activation Approval Queue",
  "description": "Generated approval packets for dry-run runtime activation and source turnoff operations.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "packets"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "RUNTIME_ACTIVATION_APPROVAL_QUEUE"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "packets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approvalPacket"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "operationType": {
      "type": "string",
      "enum": [
        "ACTIVATE_RUNTIME_LINK",
        "IMPORT_MARKETPLACE",
        "REPLACE_SOURCE_WITH_SYMLINK"
      ]
    },
    "planStatus": {
      "type": "string",
      "enum": [
        "READY_FOR_MANUAL_IMPORT",
        "WAITING_APPROVAL",
        "WAITING_REVIEW"
      ]
    },
    "preflightStatus": {
      "type": "string",
      "enum": [
        "ALREADY_ACTIVE",
        "BLOCKED",
        "READY_FOR_APPROVAL",
        "REVIEW_REQUIRED"
      ]
    },
    "approvalState": {
      "type": "string",
      "enum": [
        "ALREADY_ACTIVE",
        "BLOCKED",
        "READY_FOR_APPROVAL",
        "READY_FOR_MANUAL_IMPORT",
        "REVIEW_REQUIRED"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "HIGH",
        "LOW",
        "MEDIUM"
      ]
    },
    "runtimeLinkStrategy": {
      "type": "string",
      "enum": [
        "MARKETPLACE_IMPORT",
        "SYMLINK_CHILDREN",
        "SYMLINK_FILE",
        "SYMLINK_TREE"
      ]
    },
    "pathKind": {
      "type": "string",
      "enum": [
        "DIRECTORY",
        "FILE",
        "MISSING",
        "OTHER",
        "SYMLINK",
        "VIRTUAL"
      ]
    },
    "childCollision": {
      "type": "object",
      "required": [
        "type",
        "name",
        "sourcePath",
        "targetPath",
        "targetKind"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_CHILD_COLLISION"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "targetKind": {
          "$ref": "#/$defs/pathKind"
        }
      },
      "additionalProperties": false
    },
    "dependencyPacket": {
      "type": "object",
      "required": [
        "type",
        "name",
        "targetPath",
        "reason"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_DEPENDENCY_PACKET"
          ]
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "sourceTurnoffReadiness",
        "runtimeActivationPlan",
        "runtimeActivationPreflight",
        "cleanupLedger",
        "runtimeLinks"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_APPROVAL_INPUTS"
          ]
        },
        "sourceTurnoffReadiness": {
          "$ref": "#/$defs/path"
        },
        "runtimeActivationPlan": {
          "$ref": "#/$defs/path"
        },
        "runtimeActivationPreflight": {
          "$ref": "#/$defs/path"
        },
        "cleanupLedger": {
          "$ref": "#/$defs/path"
        },
        "runtimeLinks": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "sourceTurnoffStatus",
        "totalPackets",
        "readyForApproval",
        "readyForManualImport",
        "reviewRequired",
        "blocked",
        "alreadyActive",
        "runtimeMutationAllowed",
        "approvalRequired",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_APPROVAL_SUMMARY"
          ]
        },
        "sourceTurnoffStatus": {
          "type": "string",
          "enum": [
            "APPROVED_FOR_EXECUTION",
            "EXECUTION_COMPLETE",
            "NOT_READY",
            "REVIEW_READY"
          ]
        },
        "totalPackets": {
          "type": "integer",
          "minimum": 0
        },
        "readyForApproval": {
          "type": "integer",
          "minimum": 0
        },
        "readyForManualImport": {
          "type": "integer",
          "minimum": 0
        },
        "reviewRequired": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "alreadyActive": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeMutationAllowed": {
          "type": "boolean"
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "approvalEvidence": {
      "type": "object",
      "required": [
        "type",
        "manifest",
        "preflightReport",
        "status"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_APPROVAL_EVIDENCE"
          ]
        },
        "manifest": {
          "$ref": "#/$defs/path"
        },
        "preflightReport": {
          "$ref": "#/$defs/path"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "reviewEvidenceSha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "stepPreview": {
      "type": "object",
      "required": [
        "type",
        "description",
        "commandPreview"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_APPROVAL_STEP"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "commandPreview": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "approvalPacket": {
      "type": "object",
      "required": [
        "type",
        "name",
        "operationType",
        "approvalState",
        "planStatus",
        "preflightStatus",
        "riskLevel",
        "requiresApproval",
        "sourcePath",
        "targetPath",
        "sourceKind",
        "targetKind",
        "evidence",
        "preflightReasons",
        "approvalBoundary",
        "rollback",
        "stepPreviews"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "RUNTIME_ACTIVATION_APPROVAL_PACKET"
          ]
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "operationType": {
          "$ref": "#/$defs/operationType"
        },
        "approvalState": {
          "$ref": "#/$defs/approvalState"
        },
        "planStatus": {
          "$ref": "#/$defs/planStatus"
        },
        "preflightStatus": {
          "$ref": "#/$defs/preflightStatus"
        },
        "riskLevel": {
          "$ref": "#/$defs/riskLevel"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "targetPath": {
          "$ref": "#/$defs/path"
        },
        "backupPath": {
          "$ref": "#/$defs/path"
        },
        "sourceKind": {
          "$ref": "#/$defs/pathKind"
        },
        "targetKind": {
          "$ref": "#/$defs/pathKind"
        },
        "backupKind": {
          "$ref": "#/$defs/pathKind"
        },
        "runtimeLinkStrategy": {
          "$ref": "#/$defs/runtimeLinkStrategy"
        },
        "primitiveTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/primitiveType"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "collisionPolicy": {
          "type": "string",
          "minLength": 1
        },
        "childCollisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/childCollision"
          },
          "minItems": 1
        },
        "dependencyPackets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependencyPacket"
          },
          "minItems": 1
        },
        "evidence": {
          "$ref": "#/$defs/approvalEvidence"
        },
        "preflightReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "approvalBoundary": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "stepPreviews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepPreview"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
