{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-digest-review-decisions.schema.json",
  "title": "Intelligence Digest Review Decisions",
  "description": "Durable review decisions for generated duplicate-content groups before runtime replacement or cleanup planning.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "policy",
    "entries"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "DIGEST_REVIEW_DECISIONS"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/digestReviewDecision"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "primitiveType": {
      "type": "string",
      "enum": [
        "AGENT",
        "HOOK",
        "INSTRUCTION",
        "PLUGIN",
        "SKILL"
      ]
    },
    "reviewDecision": {
      "type": "string",
      "enum": [
        "COVERED_BY_CANONICAL",
        "RETAIN_EXTERNAL",
        "REVIEW_REQUIRED"
      ]
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "DECIDED",
        "NEEDS_REVIEW"
      ]
    },
    "digestReviewTarget": {
      "type": "object",
      "required": [
        "type",
        "sha256"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "DIGEST_REVIEW_TARGET"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "digestQueueEvidence": {
      "type": "object",
      "required": [
        "type",
        "queueType",
        "generatedAction",
        "priority",
        "entryCount",
        "buckets",
        "sourceRoots",
        "candidateKeys"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "DIGEST_QUEUE_EVIDENCE"
          ]
        },
        "queueType": {
          "type": "string",
          "enum": [
            "DIGEST_REVIEW"
          ]
        },
        "generatedAction": {
          "type": "string",
          "enum": [
            "REPLACE_DUPLICATES_WITH_REFERENCES_AFTER_REVIEW"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "entryCount": {
          "type": "integer",
          "minimum": 2
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "sourceRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "candidateKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(AGENT|HOOK|INSTRUCTION|PLUGIN|SKILL):[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "canonicalCoverage": {
      "type": "object",
      "required": [
        "type",
        "path",
        "notes"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CANONICAL_COVERAGE"
          ]
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "digestReviewDecision": {
      "type": "object",
      "required": [
        "type",
        "target",
        "decision",
        "status",
        "queueEvidence",
        "rationale",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "DIGEST_REVIEW_DECISION"
          ]
        },
        "target": {
          "$ref": "#/$defs/digestReviewTarget"
        },
        "decision": {
          "$ref": "#/$defs/reviewDecision"
        },
        "status": {
          "$ref": "#/$defs/reviewStatus"
        },
        "queueEvidence": {
          "$ref": "#/$defs/digestQueueEvidence"
        },
        "canonicalCoverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonicalCoverage"
          },
          "minItems": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
