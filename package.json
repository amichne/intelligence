{
  "name": "intelligence",
  "private": true,
  "scripts": {
    "intelligence": "python3 scripts/intelligence.py",
    "package:cli": "python3 scripts/package-intelligence.py --out dist",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "apm:manifest:check": "python3 scripts/prepare-apm-marketplace.py manifest --check",
    "apm:stage": "python3 scripts/prepare-apm-marketplace.py stage --out build/apm-marketplace --check-root-manifest",
    "apm:pack:preview": "npm run apm:stage && cd build/apm-marketplace && apm pack --marketplace=all --dry-run --check-versions --json",
    "schema:policy": "node source/skills/manage-json-schemas/scripts/schema-contracts.js policy-tree --root source/skills/manage-json-schemas/references/schemas",
    "docs:build": "zensical build --clean",
    "docs:serve": "zensical serve"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
