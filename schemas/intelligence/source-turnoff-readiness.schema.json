{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-source-turnoff-readiness.schema.json",
  "title": "Intelligence Source Turnoff Readiness",
  "description": "Generated readiness report for reviewing whether scattered source roots can be replaced by canonical primitives and runtime links.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "gates",
    "proposedReplacements"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "SOURCE_TURNOFF_READINESS_REPORT"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "proposedReplacements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/replacementProposal"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "readinessStatus": {
      "type": "string",
      "enum": [
        "APPROVED_FOR_EXECUTION",
        "EXECUTION_COMPLETE",
        "NOT_READY",
        "REVIEW_READY"
      ]
    },
    "gateStatus": {
      "type": "string",
      "enum": [
        "BLOCKED",
        "PASS",
        "REVIEW_REQUIRED"
      ]
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "pluginCoverage",
        "reviewCompleteness",
        "sourceReviewDecisions",
        "digestReviewDecisions",
        "cleanupLedger",
        "runtimeLinks"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_TURNOFF_READINESS_INPUTS"
          ]
        },
        "pluginCoverage": {
          "$ref": "#/$defs/path"
        },
        "reviewCompleteness": {
          "$ref": "#/$defs/path"
        },
        "sourceReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "digestReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "cleanupLedger": {
          "$ref": "#/$defs/path"
        },
        "runtimeLinks": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "readinessStatus",
        "allCanonicalRouted",
        "reviewCompletenessOpen",
        "sourceReviewOpen",
        "digestReviewOpen",
        "proposedReplacements",
        "approvedReplacements",
        "executedCleanupEntries",
        "retainedExternalGroups",
        "runtimeLinksRequiringApproval",
        "canMutateRuntimeWithoutApproval",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_TURNOFF_READINESS_SUMMARY"
          ]
        },
        "readinessStatus": {
          "$ref": "#/$defs/readinessStatus"
        },
        "allCanonicalRouted": {
          "type": "boolean"
        },
        "reviewCompletenessOpen": {
          "type": "integer",
          "minimum": 0
        },
        "sourceReviewOpen": {
          "type": "integer",
          "minimum": 0
        },
        "digestReviewOpen": {
          "type": "integer",
          "minimum": 0
        },
        "proposedReplacements": {
          "type": "integer",
          "minimum": 0
        },
        "approvedReplacements": {
          "type": "integer",
          "minimum": 0
        },
        "executedCleanupEntries": {
          "type": "integer",
          "minimum": 0
        },
        "retainedExternalGroups": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeLinksRequiringApproval": {
          "type": "integer",
          "minimum": 0
        },
        "canMutateRuntimeWithoutApproval": {
          "type": "boolean"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": [
        "type",
        "name",
        "status",
        "evidence",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_TURNOFF_GATE"
          ]
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "replacementProposal": {
      "type": "object",
      "required": [
        "type",
        "sourceRoot",
        "sourcePath",
        "canonicalPath",
        "decision",
        "status",
        "reviewEvidenceSha256"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_REPLACEMENT_PROPOSAL"
          ]
        },
        "sourceRoot": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "canonicalPath": {
          "$ref": "#/$defs/path"
        },
        "decision": {
          "type": "string",
          "enum": [
            "REPLACE_WITH_SYMLINK"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "PROPOSED"
          ]
        },
        "reviewEvidenceSha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    }
  }
}
