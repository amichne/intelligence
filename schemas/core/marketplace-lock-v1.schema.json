{
  "$defs": {
    "asset": {
      "oneOf": [
        {
          "$ref": "#/$defs/githubAsset"
        },
        {
          "$ref": "#/$defs/localAsset"
        }
      ]
    },
    "assetName": {
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "type": "string"
    },
    "entry": {
      "additionalProperties": false,
      "properties": {
        "checksum": {
          "$ref": "#/$defs/asset"
        },
        "index": {
          "$ref": "#/$defs/asset"
        },
        "marketplaceId": {
          "$ref": "#/$defs/identifier"
        },
        "packages": {
          "items": {
            "$ref": "#/$defs/package"
          },
          "maxItems": 512,
          "minItems": 1,
          "type": "array"
        },
        "source": {
          "oneOf": [
            {
              "$ref": "#/$defs/githubSource"
            },
            {
              "$ref": "#/$defs/localSource"
            }
          ]
        }
      },
      "required": [
        "checksum",
        "index",
        "marketplaceId",
        "packages",
        "source"
      ],
      "type": "object"
    },
    "githubAsset": {
      "additionalProperties": false,
      "properties": {
        "assetId": {
          "$ref": "#/$defs/positiveId"
        },
        "name": {
          "$ref": "#/$defs/assetName"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "$ref": "#/$defs/assetSize"
        }
      },
      "required": [
        "assetId",
        "name",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "githubSource": {
      "additionalProperties": false,
      "properties": {
        "immutable": {
          "const": true
        },
        "releaseId": {
          "$ref": "#/$defs/positiveId"
        },
        "repository": {
          "maxLength": 180,
          "pattern": "^(?!.*\\.git$)https://github\\.com/[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?/[a-z0-9](?:[a-z0-9._-]{0,98}[a-z0-9])?$",
          "type": "string"
        },
        "tag": {
          "$ref": "#/$defs/identifier"
        },
        "tagCommitSha": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "type": {
          "const": "GITHUB_RELEASE"
        }
      },
      "required": [
        "immutable",
        "releaseId",
        "repository",
        "tag",
        "tagCommitSha",
        "type"
      ],
      "type": "object"
    },
    "identifier": {
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "localAsset": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/assetName"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "$ref": "#/$defs/assetSize"
        }
      },
      "required": [
        "name",
        "sha256",
        "size"
      ],
      "type": "object"
    },
    "localSource": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "maxLength": 240,
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//)(?!.*\\\\)(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "type": {
          "const": "LOCAL_SNAPSHOT"
        }
      },
      "required": [
        "path",
        "type"
      ],
      "type": "object"
    },
    "package": {
      "additionalProperties": false,
      "properties": {
        "archive": {
          "$ref": "#/$defs/asset"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        }
      },
      "required": [
        "archive",
        "name"
      ],
      "type": "object"
    },
    "positiveId": {
      "maximum": 9007199254740991,
      "minimum": 1,
      "type": "integer"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "assetSize": {
      "maximum": 268435456,
      "minimum": 1,
      "type": "integer"
    }
  },
  "$id": "https://github.com/amichne/intelligence/schemas/core/marketplace-lock-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "items": {
        "$ref": "#/$defs/entry"
      },
      "maxItems": 128,
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {
      "const": 1
    },
    "type": {
      "const": "MARKETPLACE_LOCK"
    }
  },
  "required": [
    "entries",
    "schemaVersion",
    "type"
  ],
  "title": "Portable Intelligence marketplace lock V1",
  "type": "object"
}
