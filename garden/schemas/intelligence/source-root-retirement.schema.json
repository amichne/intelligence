{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intelligence-source-root-retirement.schema.json",
  "title": "Intelligence Source Root Retirement",
  "description": "Generated source-root retirement and retention view for scanned AI tooling primitive roots.",
  "type": "object",
  "required": [
    "type",
    "schemaVersion",
    "generatedFrom",
    "summary",
    "roots"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "SOURCE_ROOT_RETIREMENT_REPORT"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "generatedFrom": {
      "$ref": "#/$defs/generatedFrom"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "roots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/root"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "sourceRootRole": {
      "type": "string",
      "enum": [
        "backup-source",
        "canonical-candidate",
        "local-repo-source",
        "runtime-source"
      ]
    },
    "retirementState": {
      "type": "string",
      "enum": [
        "CANONICAL_OWNER",
        "CLEANUP_RECORDED",
        "COVERED_NO_REPLACEMENT_PLAN",
        "EMPTY_SOURCE_ROOT",
        "MIXED_RETAIN_AND_COVERED",
        "NO_ACTION_RECORDED",
        "PARTIAL_REPLACEMENT_READY",
        "RETAIN_EXTERNAL_OWNER",
        "RUNTIME_DEPENDENCY_MAPPED",
        "RUNTIME_REVIEW_REQUIRED"
      ]
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "type",
        "sourceRoots",
        "discoveredPrimitives",
        "sourceReviewDecisions",
        "digestReviewDecisions",
        "sourceRootDecisions",
        "cleanupLedger",
        "runtimeActivationApprovals"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_RETIREMENT_INPUTS"
          ]
        },
        "sourceRoots": {
          "$ref": "#/$defs/path"
        },
        "discoveredPrimitives": {
          "$ref": "#/$defs/path"
        },
        "sourceReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "digestReviewDecisions": {
          "$ref": "#/$defs/path"
        },
        "sourceRootDecisions": {
          "$ref": "#/$defs/path"
        },
        "cleanupLedger": {
          "$ref": "#/$defs/path"
        },
        "runtimeActivationApprovals": {
          "$ref": "#/$defs/path"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "type",
        "totalRoots",
        "canonicalOwners",
        "partialReplacementReady",
        "runtimeDependencyMapped",
        "runtimeReviewRequired",
        "coveredNoReplacementPlan",
        "retainExternalOwners",
        "mixedRetainAndCovered",
        "cleanupRecorded",
        "emptySourceRoots",
        "noActionRecorded",
        "totalObservedEntries",
        "nextAction"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_RETIREMENT_SUMMARY"
          ]
        },
        "totalRoots": {
          "type": "integer",
          "minimum": 0
        },
        "canonicalOwners": {
          "type": "integer",
          "minimum": 0
        },
        "partialReplacementReady": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeDependencyMapped": {
          "type": "integer",
          "minimum": 0
        },
        "runtimeReviewRequired": {
          "type": "integer",
          "minimum": 0
        },
        "coveredNoReplacementPlan": {
          "type": "integer",
          "minimum": 0
        },
        "retainExternalOwners": {
          "type": "integer",
          "minimum": 0
        },
        "mixedRetainAndCovered": {
          "type": "integer",
          "minimum": 0
        },
        "cleanupRecorded": {
          "type": "integer",
          "minimum": 0
        },
        "emptySourceRoots": {
          "type": "integer",
          "minimum": 0
        },
        "noActionRecorded": {
          "type": "integer",
          "minimum": 0
        },
        "totalObservedEntries": {
          "type": "integer",
          "minimum": 0
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "decisionSummary": {
      "type": "object",
      "required": [
        "type",
        "sourceCoveredByCanonical",
        "sourceRetainedExternal",
        "sourceKeepCanonical",
        "digestCoveredByCanonical",
        "digestRetainedExternal",
        "rootRetainedExternal",
        "rootPromoteCandidates",
        "rootReviewRequired"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_DECISION_SUMMARY"
          ]
        },
        "sourceCoveredByCanonical": {
          "type": "integer",
          "minimum": 0
        },
        "sourceRetainedExternal": {
          "type": "integer",
          "minimum": 0
        },
        "sourceKeepCanonical": {
          "type": "integer",
          "minimum": 0
        },
        "digestCoveredByCanonical": {
          "type": "integer",
          "minimum": 0
        },
        "digestRetainedExternal": {
          "type": "integer",
          "minimum": 0
        },
        "rootRetainedExternal": {
          "type": "integer",
          "minimum": 0
        },
        "rootPromoteCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "rootReviewRequired": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "cleanupSummary": {
      "type": "object",
      "required": [
        "type",
        "proposed",
        "approved",
        "executed"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_CLEANUP_SUMMARY"
          ]
        },
        "proposed": {
          "type": "integer",
          "minimum": 0
        },
        "approved": {
          "type": "integer",
          "minimum": 0
        },
        "executed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "approvalSummary": {
      "type": "object",
      "required": [
        "type",
        "readyForApproval",
        "readyForManualImport",
        "reviewRequired",
        "dependencyMapped",
        "blocked",
        "alreadyActive"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_APPROVAL_SUMMARY"
          ]
        },
        "readyForApproval": {
          "type": "integer",
          "minimum": 0
        },
        "readyForManualImport": {
          "type": "integer",
          "minimum": 0
        },
        "reviewRequired": {
          "type": "integer",
          "minimum": 0
        },
        "dependencyMapped": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "alreadyActive": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "root": {
      "type": "object",
      "required": [
        "type",
        "sourceRoot",
        "sourcePath",
        "role",
        "observedEntries",
        "decisionSummary",
        "cleanupSummary",
        "approvalSummary",
        "retirementState",
        "nextAction",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SOURCE_ROOT_RETIREMENT_ENTRY"
          ]
        },
        "sourceRoot": {
          "$ref": "#/$defs/name"
        },
        "sourcePath": {
          "$ref": "#/$defs/path"
        },
        "resolvedPath": {
          "$ref": "#/$defs/path"
        },
        "role": {
          "$ref": "#/$defs/sourceRootRole"
        },
        "observedEntries": {
          "type": "integer",
          "minimum": 0
        },
        "decisionSummary": {
          "$ref": "#/$defs/decisionSummary"
        },
        "cleanupSummary": {
          "$ref": "#/$defs/cleanupSummary"
        },
        "approvalSummary": {
          "$ref": "#/$defs/approvalSummary"
        },
        "retirementState": {
          "$ref": "#/$defs/retirementState"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
