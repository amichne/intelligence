{
  "type": "WORKFLOW_PROFILE",
  "schemaVersion": 1,
  "name": "kotlin-repo-default",
  "description": "Default Kotlin repository workflow using the single Kotlin Agentic Correctness plugin and Codex hook adapters.",
  "marketplaces": [
    {
      "type": "WORKFLOW_MARKETPLACE",
      "name": "amichne-intelligence",
      "provider": "codex",
      "source": "https://github.com/amichne/intelligence/tree/codex",
      "entrypoint": ".agents/plugins/marketplace.json",
      "scope": "plugins in this workflow profile"
    }
  ],
  "plugins": [
    "kotlin-agentic-correctness"
  ],
  "hooks": [
    {
      "type": "WORKFLOW_HOOK",
      "name": "agents-md-turn-refresh",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "required-skill-read",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "kotlin-horizontalization-check",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "gradle-check-green",
      "adapter": "codex"
    }
  ],
  "validation": {
    "type": "WORKFLOW_VALIDATION",
    "commands": [
      "node scripts/validate-manifests.mjs"
    ]
  }
}
